{
  "name": "unsaved-files-viewer",
  "displayName": "Unsaved Files Viewer",
  "description": "Shows all currently unsaved files in a sidebar view.",
  "version": "0.0.1",
  "publisher": "polskiedev",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:unsavedFilesView"
  ],
  "main": "./extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "unsavedFilesView",
          "name": "Unsaved Files"
        }
      ]
    },
    "commands": [
      {
        "command": "unsavedFiles.refresh",
        "title": "Refresh Unsaved Files"
      },
      {
        "command": "unsavedFiles.open",
        "title": "Open File"
      },
      {
        "command": "unsavedFiles.close",
        "title": "Close Unsaved File"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "unsavedFiles.refresh",
          "when": "view == unsavedFilesView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "unsavedFiles.close",
          "when": "view == unsavedFilesView",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "package-extension": "node scripts/package.js"
  }
}
